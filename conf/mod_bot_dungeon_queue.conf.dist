[worldserver]

###############################################################################
# mod-bot-dungeon-queue configuration
###############################################################################
#
# Controls how random bots form dungeon groups, queue for instance content,
# and exit after completing (or wiping in) a dungeon.

###############################################################################
# MASTER SWITCH
###############################################################################

BotDungeonQueue.Enable = 1

###############################################################################
# QUEUE TIMING
###############################################################################

# How often (in seconds) the module checks for eligible bots to form new
# dungeon groups. Lower = more responsive but higher CPU.
BotDungeonQueue.QueueInterval = 30

# Minimum time (in seconds) between new dungeon groups. Throttles group
# formation so dungeons pop gradually instead of all at once. Set to 0 for
# no throttle (every queue tick may form groups if bots are available).
# Suggested values: 60 (1 min), 300 (5 min), 900 (15 min), 1200 (20 min).
BotDungeonQueue.GroupInterval = 60

# When enabled, the role pools (tank/healer/dps) are shuffled before forming
# groups so the same bots aren't always picked in the same order. Disable for
# deterministic debugging when you need consistent group composition.
BotDungeonQueue.ShufflePool = 1

# Minimum level a bot must be to join a dungeon group. Default 15 (RFC).
BotDungeonQueue.MinLevel = 15

# Maximum percentage of online bots that can be inside dungeons at any time.
# 0 = unlimited (no cap). Suggested values: 10, 20, 30, 40.
BotDungeonQueue.MaxBotsPct = 50

# Maximum number of active dungeon groups (instances) at any time.
# 0 = unlimited (no cap). When set, limits the total concurrent dungeon
# instances regardless of how many bots are inside. Useful paired with
# MaxBotsPct when you want both a bot-count cap and a group-count cap.
BotDungeonQueue.MaxActiveDungeons = 0

###############################################################################
# BG COMPATIBILITY
###############################################################################

# When enabled, bots already in the BG queue will not be considered for
# dungeon groups. When disabled, BGs and dungeons compete for the same bots.
BotDungeonQueue.RespectBgQueue = 1

###############################################################################
# COMMUNICATION
###############################################################################

# Controls how bots respond to player chat inside dungeons.
# 0 = always /say
# 1 = whisper when a specific player is the target (fallback to /say otherwise)
BotDungeonQueue.WhisperReplies = 1

###############################################################################
# TELEPORT-OUT ON DEATH
###############################################################################

# When a bot dies inside a dungeon and the group cannot recover, the run is
# abandoned and all surviving members are teleported home.
# 0 = disabled (bots stay dead in the dungeon until server restart)
# 1 = enabled (recommended)
BotDungeonQueue.TeleportOutOnDeath = 1

###############################################################################
# WIPE LIMITS
###############################################################################

# Maximum number of full-party wipes before the group is evicted from the
# instance and disbanded. Solo deaths (where most of the party survives) do
# not count toward this limit.
BotDungeonQueue.MaxWipesBeforeEvict = 4

###############################################################################
# STUCK BOT CLEANUP
###############################################################################

# How often (in seconds) to sweep for bots stuck alone in dungeons and
# teleport them home. 5 minutes gives groups time to form and navigate
# toward the boss before the first sweep.
BotDungeonQueue.StuckCleanupInterval = 300

# How long (in seconds) after entering a dungeon a bot is exempt from the
# stuck cleanup. Prevents the cleanup from teleporting a group leader home
# before the other 4 members finish their teleport. Should cover the time
# from queue-check teleport through the deferred-follower teleports plus
# initial group movement into the instance. 5 minutes matches the cleanup
# interval so bots survive at least one full cycle.
BotDungeonQueue.StuckCleanupGracePeriod = 300
